{
  "license": "MIT",
  "type": "wordpress-project",
  "name": "dashifen/dashifen.com",
  "description": "Composer based dev and deployment process for dashifen.com.",
  "authors": [
    {
      "name": "David Dashifen Kees",
      "email": "dashifen@dashifen.com",
      "role": "developer"
    }
  ],
  "require": {
    "php": ">=8.2",
    "dashifen/composer-scripts": "dev-main",
    "dashifen/wp-mu-plugin-anti-brute-squad": "^3.0",
    "dashifen/wp-mu-plugin-loader": "^2.0",
    "dashifen/wp-plugin-abbreviator": "^2.0",
    "dashifen/wp-plugin-conscientious-contact-form": "^2.2",
    "dashifen/wp-plugin-deck-block": "^2.0",
    "dashifen/wp-plugin-sr5-limit-calculator": "^2.0",
    "dashifen/wp-theme-dashifen2024": "dev-main",
    "dashifen/wp-theme-the-firefly-house": "dev-main",
    "johnpbloch/wordpress": "^6.3",
    "timber/timber": "^1.22"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org"
    },
    {
      "url": "git@github.com:dashifen/composer-scripts.git",
      "type": "github"
    },
    {
      "url": "git@github.com:dashifen/wp-mu-plugin-anti-brute-squad.git",
      "type": "github"
    },
    {
      "url": "git@github.com:dashifen/wp-mu-plugin-loader.git",
      "type": "github"
    },
    {
      "url": "git@github.com:dashifen/wp-plugin-abbreviator.git",
      "type": "github"
    },
    {
      "url": "git@github.com:dashifen/wp-plugin-conscientious-contact-form.git",
      "type": "github"
    },
    {
      "url": "git@github.com:dashifen/wp-plugin-deck-block.git",
      "type": "github"
    },
    {
      "url": "git@github.com:dashifen/wp-plugin-sr5-limit-calculator.git",
      "type": "github"
    },
    {
      "url": "git@github.com:dashifen/wp-theme-dashifen2024.git",
      "type": "github"
    },
    {
      "url": "git@github.com:dashifen/wp-theme-the-firefly-house.git",
      "type": "github"
    }
  ],
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true,
      "johnpbloch/wordpress-core-installer": true
    }
  },
  "scripts": {
    "post-update-cmd": "php scripts/PostUpdateScript.php",
    "reset": "php scripts/ResetScript.php"
  },
  "extra": {
    "wordpress-install-dir": "public_html",
    "installer-paths": {
      "public_html/wp-content/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "public_html/wp-content/themes/{$name}/": [
        "type:wordpress-theme"
      ],
      "public_html/wp-content/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "public_html/wp-content/{$name}": [
        "type:wordpress-dropin"
      ]
    }
  }
}
